<UserControl
    x:Class="OrderApp.Views.Loader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:OrderApp.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:OrderApp.ViewModels"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border
            Width="180"
            Height="150"
            Background="White"
            BorderBrush="DarkGray"
            BorderThickness="1.5">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar
                    Width="130"
                    Height="12"
                    Margin="0,15,0,0"
                    IsIndeterminate="True" />

                <TextBlock
                    Margin="5"
                    HorizontalAlignment="Center"
                    Text="{Binding LoaderMessage, StringFormat='{}{0}...'}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
