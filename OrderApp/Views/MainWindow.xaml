<Window
    x:Class="OrderApp.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:OrderApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:OrderApp.ViewModels"
    xmlns:views="clr-namespace:OrderApp.Views"
    Title="Ordering Application"
    Width="800"
    Height="500"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,20,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="20"
            Text="Ordering Application" />

        <Border
            Grid.Row="1"
            Margin="20"
            Padding="20"
            BorderBrush="#F5F5F5"
            BorderThickness="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Select an item" />
                    <ComboBox
                        Margin="0,4,0,20"
                        Padding="5"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding Items}"
                        SelectedItem="{Binding SelectedItem}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <TextBlock Text="Select a state" />
                    <ComboBox
                        Margin="0,4,0,0"
                        Padding="5"
                        ItemsSource="{Binding States}"
                        SelectedItem="{Binding SelectedState}" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Enter Quanity" />
                    <TextBox
                        PreviewTextInput="NumberOnly"
                        Style="{StaticResource ValidationTextBoxStyle}"
                        Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, TargetNullValue=''}" />
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="Enter City" />
                    <TextBox Style="{StaticResource ValidationTextBoxStyle}" Text="{Binding City, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                </StackPanel>

                <Button
                    Grid.Row="4"
                    Margin="0,15,0,0"
                    Padding="5"
                    Command="{Binding PlaceOrderCommand}"
                    Content="Place order" />
            </Grid>
        </Border>

        <views:Loader Grid.RowSpan="2" />
    </Grid>
</Window>
